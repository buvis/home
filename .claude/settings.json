{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "MAX_THINKING_TOKENS": "31999",
    "NTFY_URL": "https://ntfy.buvis.net",
    "NTFY_TOPIC": "claude"
  },
  "permissions": {
    "allow": [
      "Read(~/git/**)",
      "Edit(./**)",
      "Write(./**)",
      "Write(./.local/**)",
      "Write(~/git/**/.local/**)",
      "MultiEdit(./**)",
      "Grep(*)",
      "Glob(*)",
      "WebSearch",
      "WebFetch(*)",
      "Read(~/.claude/skills/**)",
      "Bash(~/.claude/skills/*/scripts/*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(cargo:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(curl:*)",
      "Bash(showboat:*)",
      "Bash(ast-grep:*)",
      "Bash(codex:*)",
      "Bash(copilot:*)",
      "Bash(claude:*)",
      "Bash(mise:*)",
      "Bash(mdbook:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(xxd:*)",
      "Bash(test:*)",
      "Bash(timeout:*)",
      "Bash(lsof:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(dig:*)",
      "Bash(ffmpeg:*)",
      "Bash(ffprobe:*)",
      "Bash(.local/tmp/*)",
      "Bash(* --help*)",
      "Bash(* --version)",
      "mcp__serena__*",
      "mcp__claude_ai_Context7__*",
      "mcp__MCP_DOCKER__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(sudo *)",
      "Bash(chown *)",
      "Bash(chmod 7* *)",
      "Bash(curl * | bash)",
      "Bash(wget * -O - | sh)",
      "Bash(eval *)",
      "Bash(source <(*))",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git clean -fd *)",
      "Bash(docker build *)",
      "Bash(docker push *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(npm run deploy*)",
      "Bash(pnpm run deploy*)",
      "Bash(yarn deploy*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "warden@buvis-plugins": true,
    "warden@claude-warden": true
  },
  "extraKnownMarketplaces": {
    "buvis-plugins": {
      "source": {
        "source": "github",
        "repo": "buvis/claude-plugins"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "youtube_transcript": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/youtube-transcript"
      ]
    }
  }
}
