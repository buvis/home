{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skillListingBudgetFraction": 0.03,
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/bob/.claude/plugins/cache/ponytail/ponytail/4.7.0/hooks/ponytail-statusline.sh\""
  },
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "MAX_THINKING_TOKENS": "31999",
    "NTFY_URL": "https://ntfy.buvis.net",
    "NTFY_TOPIC": "claude"
  },
  "permissions": {
    "allow": [
      "Read(~/git/**)",
      "Edit(./**)",
      "Write(./**)",
      "Write(./dev/local/**)",
      "Write(~/git/**/dev/local/**)",
      "Read(/tmp/**)",
      "Read(/tmp/*)",
      "Read(/private/tmp/**)",
      "Read(/private/tmp/*)",
      "Read(/var/folders/**)",
      "Read(/var/folders/*)",
      "Read(/private/var/folders/**)",
      "Read(/private/var/folders/*)",
      "Write(/tmp/**)",
      "Write(/tmp/*)",
      "Write(/private/tmp/**)",
      "Write(/private/tmp/*)",
      "Write(/var/folders/**)",
      "Write(/var/folders/*)",
      "Write(/private/var/folders/**)",
      "Write(/private/var/folders/*)",
      "Edit(/tmp/**)",
      "Edit(/tmp/*)",
      "Edit(/private/tmp/**)",
      "Edit(/private/tmp/*)",
      "Edit(/var/folders/**)",
      "Edit(/var/folders/*)",
      "Edit(/private/var/folders/**)",
      "Edit(/private/var/folders/*)",
      "Read(tmp/**)",
      "Read(tmp/*)",
      "Read(**/tmp/**)",
      "Read(**/tmp/*)",
      "Write(tmp/**)",
      "Write(tmp/*)",
      "Write(**/tmp/**)",
      "Write(**/tmp/*)",
      "Edit(tmp/**)",
      "Edit(tmp/*)",
      "Edit(**/tmp/**)",
      "Edit(**/tmp/*)",
      "Grep(*)",
      "Glob(*)",
      "WebSearch",
      "WebFetch(*)",
      "Read(~/.claude/skills/**)",
      "Read(~/.claude/dev/local/**)",
      "Read(~/.claude/dev/local/*)",
      "Write(~/.claude/dev/local/**)",
      "Write(~/.claude/dev/local/*)",
      "Edit(~/.claude/dev/local/**)",
      "Edit(~/.claude/dev/local/*)",
      "Read(/Users/bob/.local/tmp/claude-dev/**)",
      "Read(/Users/bob/.local/tmp/claude-dev/*)",
      "Write(/Users/bob/.local/tmp/claude-dev/**)",
      "Write(/Users/bob/.local/tmp/claude-dev/*)",
      "Edit(/Users/bob/.local/tmp/claude-dev/**)",
      "Edit(/Users/bob/.local/tmp/claude-dev/*)",
      "mcp__claude_ai_Context7__*",
      "mcp__plugin_context-mode_context-mode__*",
      "Bash(git:*)",
      "Bash(rm:*)",
      "Bash(gh:*)",
      "Bash(cargo:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(showboat:*)",
      "Bash(zdb:*)",
      "Bash(ast-grep:*)",
      "Bash(mdbook:*)",
      "Bash(codex:*)",
      "Bash(copilot:*)",
      "Bash(claude:*)",
      "Bash(mise:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(bash -n:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(xxd:*)",
      "Bash(test:*)",
      "Bash(timeout:*)",
      "Bash(lsof:*)",
      "Bash(dig:*)",
      "Bash(ffmpeg:*)",
      "Bash(ffprobe:*)",
      "Bash(mkdocs:*)",
      "Bash(rmdir:*)",
      "Bash(shellcheck:*)",
      "Bash(rustc:*)",
      "Bash(gpgconf:*)",
      "Bash(ddb:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(sqlite3:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(stat:*)",
      "Bash(du:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Read(**/id_dsa)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/Users/bob/.local/tmp/claude-dev"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/cartographer-recon-brief.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/enforce_prd_location.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/gateguard-fact-force.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/cartographer-echo.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/enforce_prd_location.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/gateguard-fact-force.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/cartographer-echo.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__serena__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/cartographer-echo.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/set-pidash-attention.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/set-pidash-attention.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/run-autopilot/scripts/autopilot_stop_hook.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/run-autopilot/scripts/review_coverage_hook.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/track_cost.py",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/cleanup-pidash-session.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/analyze-instincts.py",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/cartographer-stop.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/design-quality-check.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/update-pidash-tasks.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/sync-pidash-on-agent-return.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/clear-pidash-attention.py",
            "timeout": 3
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/observe_tool.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/run-autopilot/scripts/autopilot_yield_clear_hook.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep|Glob|Agent|WebFetch|WebSearch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/run-autopilot/scripts/autopilot_context_cap_hook.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/bob/.claude/hooks/context-mode-cache-heal.mjs\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "warden@buvis-plugins": true,
    "git-ferry@buvis-plugins": true,
    "strunk@buvis-plugins": true,
    "aegis@buvis-plugins": true,
    "claude-checkup@buvis-plugins": true,
    "context-mode@context-mode": true,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "buvis-plugins": {
      "source": {
        "source": "github",
        "repo": "buvis/claude-plugins"
      },
      "autoUpdate": true
    },
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "Writes, edits, and deletes under any `dev/local/` directory (including `~/.claude/dev/local/`) are working documents — PRDs, autopilot state, scratch files, plans, signal files. They are NOT agent configuration or self-modification. Allow without prompting.",
      "Reads, writes, edits, and deletes under any temporary directory — absolute (`/tmp/`, `/private/tmp/`, `/var/folders/`, `/private/var/folders/`) or relative (`tmp/`, `**/tmp/`) — are scratch artifacts (dispatch prompts, test logs, intermediate files). They are NOT agent configuration or self-modification. Allow without prompting."
    ]
  }
}
