{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skillListingBudgetFraction": 0.03,
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "MAX_THINKING_TOKENS": "31999",
    "NTFY_URL": "https://ntfy.buvis.net",
    "NTFY_TOPIC": "claude"
  },
  "permissions": {
    "allow": [
      "Read(~/git/**)",
      "Edit(./**)",
      "Write(./**)",
      "Write(./dev/local/**)",
      "Write(~/git/**/dev/local/**)",
      "Grep(*)",
      "Glob(*)",
      "WebSearch",
      "WebFetch(*)",
      "Read(~/.claude/skills/**)",
      "mcp__claude_ai_Context7__*",
      "Bash(git:*)",
      "Bash(rm:*)",
      "Bash(gh:*)",
      "Bash(cargo:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(showboat:*)",
      "Bash(zdb:*)",
      "Bash(ast-grep:*)",
      "Bash(mdbook:*)",
      "Bash(codex:*)",
      "Bash(copilot:*)",
      "Bash(claude:*)",
      "Bash(mise:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(xxd:*)",
      "Bash(test:*)",
      "Bash(timeout:*)",
      "Bash(lsof:*)",
      "Bash(dig:*)",
      "Bash(ffmpeg:*)",
      "Bash(ffprobe:*)",
      "Bash(mkdocs:*)",
      "Bash(rmdir:*)",
      "Bash(shellcheck:*)",
      "Bash(rustc:*)",
      "Bash(gpgconf:*)",
      "Bash(ddb:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(bash:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(sqlite3:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(stat:*)",
      "Bash(du:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/protect_config.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/enforce_prd_location.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-suppression-markers.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/gateguard-fact-force.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/validate_commit_msg.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block_devlocal_redirects.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/enforce_prd_location.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/gateguard-fact-force.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/prefer-tools.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/set-pidash-attention.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/set-pidash-attention.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/run-autopilot/scripts/autopilot_stop_hook.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/track_cost.py",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/cleanup-pidash-session.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/analyze-instincts.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/design-quality-check.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/update-pidash-tasks.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/sync-pidash-on-agent-return.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/clear-pidash-attention.py",
            "timeout": 3
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/observe_tool.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "warden@buvis-plugins": true,
    "harness@harness-marketplace": true
  },
  "extraKnownMarketplaces": {
    "buvis-plugins": {
      "source": {
        "source": "github",
        "repo": "buvis/claude-plugins"
      },
      "autoUpdate": true
    },
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "mcpServers": {
    "youtube_transcript": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/youtube-transcript"
      ]
    }
  }
}
