<?xml version="1.0" encoding="utf-8"?>
<Theme name="SolarizedColorful" author="Tomáš Bouška">
  <IsDarkTheme description="Specifies if the theme is derived from a dark theme">False</IsDarkTheme>
  <Label description="Color of labels preceding an edit control">#1393B1</Label>
  <LabelDisabled description="Color of disabled labels preceding an edit control">#ACA899</LabelDisabled>
  <PopupBackground description="Color for background of popups">#0076F7</PopupBackground>
  <PopupText description="Font color for popups">#FFFFFF</PopupText>
  <RoundedCornersRadius description="Radius of control corners. Use '0' for rectangular controls">4</RoundedCornersRadius>
  <ToolStripColors description="Colors for buttons and other items in the Toolbar">
