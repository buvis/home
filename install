#!/bin/sh
# Inspired by: https://www.atlassian.com/git/tutorials/dotfiles
set -eu

info() { echo "$@" >&2; }
error() {
  echo "error: $*" >&2
  exit 1
}

REPO="$HOME/.buvis"
BACKUP="$REPO/originals-backup"

command -v git >/dev/null 2>&1 || error "git is required"

cfg() {
  /usr/bin/git --git-dir="$REPO" --work-tree="$HOME" "$@"
}

cd "$HOME" || exit 1

# Clone or fetch
if [ -d "$REPO" ]; then
  info "Updating existing repo"
  cfg config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
  cfg fetch origin
else
  git clone --bare https://github.com/buvis/home.git "$REPO"
  cfg config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
  cfg fetch origin
fi

cfg config status.showUntrackedFiles no

# Identify this machine in commits
cfg config user.name "$(hostname -s)"
cfg config user.email "$(hostname -s)@buvis.net"

# Remove leftover submodule directories from previous installs
if [ -f "$HOME/.gitmodules" ]; then
  cfg config --file .gitmodules --get-regexp path | awk '{ print $2 }' | xargs -I{} rm -rf "{}"
fi

# Checkout, backing up conflicting files if needed
if cfg checkout 2>&1; then
  info "Checked out config"
else
  info "Backing up pre-existing dot files"
  mkdir -p "$BACKUP"
  cfg checkout 2>&1 | grep -E "^\s+" | awk '{ print $1 }' >"$BACKUP/overwrites"

  while read -r path; do
    [ -e "$HOME/$path" ] || continue
    mkdir -p "$BACKUP/$(dirname "$path")"
    if [ -L "$HOME/$path" ]; then
      cp -a "$HOME/$path" "$BACKUP/$path"
      unlink "$HOME/$path"
    else
      mv "$HOME/$path" "$BACKUP/$path"
    fi
    info "Backed up $path"
  done <"$BACKUP/overwrites"

  cfg checkout || exit 1
fi

# Set up remote tracking
cfg branch -u origin/master master 2>/dev/null || true

# Retrieve submodule content
cfg submodule update --init && cfg submodule update --remote --merge

if command -v mise >/dev/null 2>&1; then
  mise install || info "warning: mise install had errors, continuing anyway"
  if command -v sysup >/dev/null 2>&1; then
    sysup nvim || info "warning: sysup nvim had errors, continuing anyway"
  fi
fi

# Install Claude CLI
info "Installing Claude CLI..."
if curl -fsSL https://claude.ai/install.sh | bash; then
  info "Claude CLI installed"
else
  info "warning: Claude CLI installation failed, continuing"
fi

# Private configs (cellar)
CELLAR="$HOME/git/src/github.com/buvis/cellar"
if [ -d "$CELLAR" ]; then
  [ -x "$CELLAR/setup.sh" ] && "$CELLAR/setup.sh"
elif git clone git@github.com:buvis/cellar.git "$CELLAR" 2>/dev/null; then
  "$CELLAR/setup.sh"
else
  info "Skipping private configs (no access to cellar)"
fi
